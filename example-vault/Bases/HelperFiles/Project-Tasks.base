filters:
  and:
    - file.inFolder("Bases/HelperFiles")
    - file.ext == "md"
    - project == this.project
formulas:
  host: this.file.link
views:
  - type: table
    name: Tasks
    filters:
      and:
        - note["latex-env"] != "table"
    order:
      - file.name
      - status
      - owner
      - priority
