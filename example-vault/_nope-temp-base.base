filters:
  and:
    - type == "book"
    - file.hasLink(file("Bases/LibraryFiles/Reading-List-2026.md"))
formulas:
  list: link("Bases/LibraryFiles/Reading-List-2026.md", "Reading-List-2026")
views:
  - type: nope-export
    name: On list
    order:
      - file.name
      - author
      - shelf
      - rating
      - status
