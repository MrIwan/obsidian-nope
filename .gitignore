# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Exclude sourcemaps
*.map

# obsidian
data.json

# Exclude macOS Finder (System Explorer) View States
.DS_Store

.env

build/

Handover-Temp.md
release_notes.md

# Generated at build time from pipeline/ + skill/ (scripts/bundle-assets.mjs)
src/generated/*

# Runtime marker written when bundled assets are extracted
.bundled-assets-version

!src/generated/bundled-assets.d.ts

# Example vault: nur kuratierte .obsidian-Config committen, Volatiles ignorieren.
# Die Plugin-Binary wird NICHT eingecheckt (keine Versionskopplung, kein Rebuild
# pro Release) — nope wird separat installiert oder lokal gesymlinkt.
# Der lokale Dev-Symlink example-vault/.obsidian/plugins/nope -> Repo-Root
# (relativ: ../../..) wird durch die plugins/-Regel unten mit-ignoriert.
example-vault/.obsidian/workspace.json
example-vault/.obsidian/workspace-mobile.json
example-vault/.obsidian/cache
example-vault/.obsidian/plugins/
