# Obsi Print – pipeline environment template
#
# The plugin sets VAULT_PATH automatically at runtime (see src/utils/docker.ts),
# so you normally do NOT need a .env file. This template is only relevant if you
# run `docker compose` manually from this directory.
#
# Copy to ".env" and set the absolute path to your Obsidian vault:
#   cp .env.example .env

VAULT_PATH="/absolute/path/to/your/vault"
