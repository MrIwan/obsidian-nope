# latexmk config for the container.
# Run makeglossaries automatically when needed.

$pdf_mode = 1;

# Use pdflatex
# Glossary deps: .glo -> .gls and .acn -> .acr trigger makeglossaries
$pdf_mode = 1;

# Glossar-Dependencies: .glo → .gls und .acn → .acr trigger makeglossaries
add_cus_dep('glo', 'gls', 0, 'run_makeglossaries');
add_cus_dep('acn', 'acr', 0, 'run_makeglossaries');

sub run_makeglossaries {
    my ($base_name, $path) = fileparse($_[0]);
    pushd $path;
    my $return = system "makeglossaries", $base_name;
    popd;
    return $return;
}

# Mark generated extensions for cleanup modes (-c/-C)
push @generated_exts, 'glo', 'gls', 'glg';
push @generated_exts, 'acn', 'acr', 'alg';
push @generated_exts, 'glsdefs';
$clean_ext .= ' %R.ist %R.xdy';